<%- include('../commons/head.com.ejs', {title: 'Account settings', additionalCss: ['structure']}) %>

<body>
    <%- include('../commons/navbar.com.ejs', {user: user, currentProject: '— select project —', currentProjectKey: '', urlSuffix: ''}) %>
    <div class="p-3">
        <h1>Account settings</h1>
        <form method="POST" action="/account">
            <div class="mb-3">
                <label class="form-label">Display name</label>
                <input class="form-control" name="displayName" value="<%= user.displayName || '' %>">
            </div>
            <div class="mb-3">
                <label class="form-label d-block">UI mode</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="uiMode" id="uiModeCode" value="code" <%= (user.uiMode || 'code') === 'code' ? 'checked' : '' %>>
                    <label class="form-check-label" for="uiModeCode">
                        <strong>code</strong> — HTML-code aesthetic (default)
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="uiMode" id="uiModeClassic" value="classic" <%= user.uiMode === 'classic' ? 'checked' : '' %>>
                    <label class="form-check-label" for="uiModeClassic">
                        <strong>classic</strong> — card/tree layout
                    </label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</body>

<%- include('../commons/foot.com.ejs') %>
