<%- include('../commons/head.com.ejs', {title: `Issue n°${issue.key} : ${issue.title}`, additionalCss: ['structure', 'issue']}) %>

<body>
    <%- include('../commons/navbar.com.ejs', {user: user, currentProject: project.name, currentProjectKey: project.key, urlSuffix: ''}) %>
    <div id="kose-metadata" data-rootIssueKey="<%= issue.key %>" data-projectKey="<%= project.key %>" style="display: none;"></div>
    <div class="p-3">
        <h1><%= issue.title %></h1>
        <% if (issue.origin === 'agent_suggestion') { %>
            <span class="badge bg-info">Agent suggestion</span>
        <% } %>
        <% if (issue.claimed_by) { %>
            <p class="text-muted small">Claimed by <code><%= issue.claimed_by %></code><% if (issue.claimed_at) { %> at <%= new Date(issue.claimed_at).toLocaleString() %><% } %></p>
        <% } %>
        <%- include('../partials/clarificationBlock.part.ejs', {issue: issue, project: project}) %>
        <table class="<%= (typeof uiMode !== 'undefined' && uiMode === 'classic') ? 'classic-detail-table' : '' %>">
            <tr data-field-name="status">
                <th>Status</th>
                <td><i class="fa fa-pencil edit-field-button"></i><i class="fa fa-check send-field-button"></i><i class="fa fa-times cancel-field-button"></i></td>
                <td><%- include('../partials/statusIssue.part.ejs') %></td>
            </tr>
            <tr data-field-name="estimation">
                <th>Estimation</th>
                <td><i class="fa fa-pencil edit-field-button"></i><i class="fa fa-check send-field-button"></i><i class="fa fa-times cancel-field-button"></i></td>
                <td><%- include('../partials/estimationIssue.part.ejs') %></td>
            </tr>
            <tr data-field-name="versionId">
                <th>Version</th>
                <td><i class="fa fa-pencil edit-field-button"></i><i class="fa fa-check send-field-button"></i><i class="fa fa-times cancel-field-button"></i></td>
                <td><%- include('../partials/versionIssue.part.ejs') %></td>
            </tr>
            <tr data-field-name="description">
                <th>Description</th>
                <td><i class="fa fa-pencil edit-field-button"></i><i class="fa fa-check send-field-button"></i><i class="fa fa-times cancel-field-button"></i></td>
                <td><%- include('../partials/descriptionIssue.part.ejs') %></td>
            </tr>
        </table>
        <% if (issue.artifacts && issue.artifacts.length) { %>
            <hr class="m-3">
            <h3>Artifacts</h3>
            <ul>
                <% for (const a of issue.artifacts) { %>
                    <li><span class="badge bg-secondary"><%= a.kind %></span> <code><%= a.ref %></code><% if (a.note) { %> — <%= a.note %><% } %></li>
                <% } %>
            </ul>
        <% } %>
        <hr class="m-3">
        <h3>Activity</h3>
        <%- include('../partials/activityLog.part.ejs', {issue: issue}) %>
        <form class="mt-2" method="POST" action="/project/<%= project.key %>/issue/<%= issue.key %>/comment">
            <div class="mb-2"><textarea class="form-control" name="body" placeholder="Add a comment..." required></textarea></div>
            <button class="btn btn-sm btn-primary" type="submit">Comment</button>
        </form>
        <% if (issue.childrenIssueList.length != 0 || true) { %>
        <hr class="m-3">
        <h3>Détail de l'implémentation :</h3>
        <%- include('../partials/backlog.part.ejs', {rootIssueList: [issue], project: project}) %>
        </div>
        <% } %>
    </div>
</body>

<%- include('../commons/foot.com.ejs') %>

<script src="/js/issue.js"></script>
<script src="/js/backlog.js"></script>
