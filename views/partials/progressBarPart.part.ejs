<% if (step == 'ready') { %><span class="bar-part ready-part" style=<%- '"width: ' + Math.floor(95*issue.chReadySp / (issue.chReadySp + issue.chDoingSp + issue.chDoneSp)) + '%;"' %>></span><% } %><% if (step == 'doing') { %><span class="bar-part doing-part" style=<%- '"width: ' + Math.floor(95*issue.chDoingSp / (issue.chReadySp + issue.chDoingSp + issue.chDoneSp)) + '%;"' %>></span><% } %><% if (step == 'done') { %><span class="bar-part done-part" style=<%- '"width: ' + Math.floor(95*issue.chDoneSp / (issue.chReadySp + issue.chDoingSp + issue.chDoneSp)) + '%;"' %>></span><% } %>
