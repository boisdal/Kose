<% if (issue.status == 'todo' || issue.status == 'ready') { %> <i class="fa fa-lightbulb" style="color: lightgray"></i> <%= issue.status == 'ready' ? 'Ready' : 'To do' %><% } %>
<% if (issue.status == 'doing' || issue.status == 'in_progress') { %> <i class="fa fa-clock" style="color: rgb(58, 203, 255)"></i> In progress<% } %>
<% if (issue.status == 'blocked') { %> <i class="fa fa-ban" style="color: orange"></i> Blocked<% } %>
<% if (issue.status == 'suggested') { %> <i class="fa fa-comment-dots" style="color: violet"></i> Suggested<% } %>
<% if (issue.status == 'done') { %> <i class="fa fa-check" style="color: lightgreen"></i> Done<% } %>
<% if (issue.status == 'released') { %> <i class="fa fa-rocket" style="color: deepskyblue"></i> Released<% } %>
